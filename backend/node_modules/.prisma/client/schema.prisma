generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EstadoOrdenCompra {
  PENDIENTE
  RECIBIDA
  CANCELADA
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
}

model Categoria {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  insumos     Insumo[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categorias")
}

model Insumo {
  id                    Int                    @id @default(autoincrement())
  nombre                String                 @unique
  unidadMedida          String
  precioActual          Float
  stockActual           Int
  stockMinimo           Int
  categoriaId           Int
  categoria             Categoria              @relation(fields: [categoriaId], references: [id])
  detallesOrden         DetalleOrden[]
  recetaIngredientes    RecetaIngrediente[]
  movimientosInventario MovimientoInventario[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@map("insumos")
}

model Proveedor {
  id                Int           @id @default(autoincrement())
  razonSocial       String
  nit               String        @unique
  telefono          String?
  email             String?
  tiempoEntregaDias Int
  ordenesCompra     OrdenCompra[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("proveedores")
}

model OrdenCompra {
  id           Int               @id @default(autoincrement())
  proveedorId  Int
  fechaEmision DateTime
  estado       EstadoOrdenCompra
  total        Float
  proveedor    Proveedor         @relation(fields: [proveedorId], references: [id])
  detalles     DetalleOrden[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@map("ordenes-compra")
}

model DetalleOrden {
  id             Int         @id @default(autoincrement())
  ordenCompraId  Int
  insumoId       Int
  cantidad       Float
  precioUnitario Float
  ordenCompra    OrdenCompra @relation(fields: [ordenCompraId], references: [id])
  insumo         Insumo      @relation(fields: [insumoId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([ordenCompraId, insumoId])
  @@map("detalle-orden")
}

model Receta {
  id           Int                 @id @default(autoincrement())
  nombre       String              @unique
  descripcion  String?
  porciones    Int
  ingredientes RecetaIngrediente[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@map("recetas")
}

model RecetaIngrediente {
  id                Int      @id @default(autoincrement())
  recetaId          Int
  insumoId          Int
  cantidadRequerida Float
  receta            Receta   @relation(fields: [recetaId], references: [id])
  insumo            Insumo   @relation(fields: [insumoId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([recetaId, insumoId])
  @@map("receta-ingredientes")
}

model MovimientoInventario {
  id        Int            @id @default(autoincrement())
  insumoId  Int
  tipo      TipoMovimiento
  cantidad  Float
  fecha     DateTime       @default(now())
  motivo    String
  insumo    Insumo         @relation(fields: [insumoId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("movimientos-inventario")
}
